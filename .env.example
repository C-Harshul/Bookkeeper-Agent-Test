# Copy to .env and fill in. Never commit .env.

# QuickBooks
QB_REALM_ID=
QB_ACCESS_TOKEN=
QB_REFRESH_TOKEN=
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:5173/callback
QB_MINOR_VERSION=69
# Optional QuickBooks defaults (see README)
# QB_DEFAULT_EXPENSE_ACCOUNT_ID=
# QB_DEFAULT_INVOICE_ITEM_ID=
# Item Id for vendor bills — must have ExpenseAccountRef in QBO (falls back to first such item, else account-only lines)
# QB_DEFAULT_BILL_ITEM_ID=
# Purchase TaxCode Id for bills when email shows tax (optional; else first suitable TaxCode from QuickBooks)
# QB_BILL_TAX_CODE_ID=

# Gmail API (OAuth) — redirect must match Google Console + UI origin
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:5173/gmail-callback
# Set automatically after OAuth:
# GMAIL_ACCESS_TOKEN=
# GMAIL_REFRESH_TOKEN=

# LLM (default: local Ollama)
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434
# Optional: trim QB reference JSON if the model/context fails (default 48000; items/vendors kept full until accounts are trimmed)
# LLM_MAX_PAYLOAD_CHARS=48000
# Optional Gemini instead:
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Optional: only process emails that mention this address (empty = all)
# TRACK_EMAIL=
