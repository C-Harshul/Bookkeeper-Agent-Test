# Copy to .env and fill in. Never commit .env.

# QuickBooks
QB_REALM_ID=
QB_ACCESS_TOKEN=
QB_REFRESH_TOKEN=
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:5173/callback
QB_MINOR_VERSION=69

# Gmail API (OAuth) — redirect must match Google Console + UI origin
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:5173/gmail-callback
# Set automatically after OAuth:
# GMAIL_ACCESS_TOKEN=
# GMAIL_REFRESH_TOKEN=

# LLM
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: only process emails that mention this address (empty = all)
# TRACK_EMAIL=
